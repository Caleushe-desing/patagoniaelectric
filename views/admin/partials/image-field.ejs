<div class="admin-image-field">
  <label><%= label %>
    <div class="admin-image-field__row">
      <input type="text" name="<%= name %>" value="<%= value %>" class="admin-image-url" placeholder="/images/... o /uploads/...">
      <label class="admin-btn admin-btn--sm admin-upload-btn">
        Subir
        <input type="file" accept="image/*" class="admin-upload-input" hidden>
      </label>
    </div>
  </label>
  <% if (value) { %><img src="<%= value %>" alt="Vista previa" class="admin-preview"><% } %>
</div>
