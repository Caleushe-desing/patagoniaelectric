<aside class="admin-sidebar">
  <div class="admin-sidebar__brand">
    <img src="/images/logo.png" alt="Patagonia Electric" class="admin-sidebar__logo">
    <div>
      <strong>Patagonia Electric</strong>
      <span>Panel de contenidos</span>
    </div>
  </div>
  <nav class="admin-sidebar__nav">
    <a href="/admin/visual" class="admin-sidebar__link admin-sidebar__link--visual <%= typeof currentSection === 'undefined' ? '' : '' %>">
      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04a1 1 0 0 0 0-1.41l-2.34-2.34a1 1 0 0 0-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/></svg>
      Editor visual
    </a>
    <a href="/admin" class="admin-sidebar__link <%= typeof currentSection === 'undefined' ? 'is-active' : '' %>">
      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z"/></svg>
      Dashboard
    </a>
    <% const groups = [
      { title: 'Configuración', keys: ['general'] },
      { title: 'Páginas', keys: ['home', 'nosotros', 'contacto'] },
      { title: 'Divisiones', keys: ['industrial', 'ecologica', 'habitacional'] },
      { title: 'Portafolio', keys: ['proyectos', 'clientes'] },
    ]; %>
    <% groups.forEach((group) => { %>
    <div class="admin-sidebar__group">
      <span class="admin-sidebar__group-title"><%= group.title %></span>
      <% group.keys.forEach((key) => { if (!sections[key]) return; %>
      <a href="/admin/edit/<%= key %>" class="admin-sidebar__link <%= currentSection === key ? 'is-active' : '' %>">
        <%= sections[key].label %>
      </a>
      <% }) %>
    </div>
    <% }) %>
  </nav>
  <div class="admin-sidebar__footer">
    <a href="/" target="_blank" class="admin-sidebar__link admin-sidebar__link--muted">Ver sitio web ↗</a>
  </div>
</aside>
