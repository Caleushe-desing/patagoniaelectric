<%- include('../partials/head') %>
<%- include('../partials/header') %>
<% const p = c.industrial; %>

<section class="page-hero">
  <div class="page-hero__bg" style="background-image:url('<%= p.heroImage %>')" <%- cmsAttr('industrial', 'heroImage', { type: 'bg-image' }) %>></div>
  <div class="page-hero__overlay"></div>
  <div class="container page-hero__content">
    <h1 class="page-hero__title" <%- cmsAttr('industrial', 'heroTitle') %>><%= p.heroTitle %></h1>
    <p class="page-hero__subtitle" <%- cmsAttr('industrial', 'heroSubtitle') %>><%= p.heroSubtitle %></p>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="page-content">
      <p class="intro-text" <%- cmsAttr('industrial', 'intro') %>><%= p.intro %></p>
      <%- include('../partials/solutions', { solutions: p.solutions, cmsSectionOverride: 'industrial' }) %>
    </div>
  </div>
</section>

<section class="section section--gray">
  <div class="container" style="text-align:center;">
    <h2 class="section__title section__title--green" <%- cmsAttr('industrial', 'ctaTitle') %>><%= p.ctaTitle %></h2>
    <a href="/contacto" class="btn btn--primary cms-allow-link"><span <%- cmsAttr('industrial', 'ctaButton') %>><%= p.ctaButton %></span></a>
  </div>
</section>

<%- include('../partials/footer') %>
<%- include('../partials/whatsapp') %>
<%- include('../partials/scripts') %>
</body>
</html>
