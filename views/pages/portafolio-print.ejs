<!DOCTYPE html>
<html lang="es-CL">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= c.portafolio.coverTitle || 'Portafolio' %> | <%= site.name %></title>
  <link href="https://fonts.googleapis.com/css2?family=Exo+2:wght@300;500;600&family=Orbitron:wght@500;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/portfolio-print.css">
</head>
<body class="pf-print<%= autoPrint ? ' pf-print--auto' : '' %>">
  <% const p = c.portafolio; %>

  <div class="pf-print-toolbar no-print">
    <div>
      <strong>Exportar portafolio a PDF</strong>
      <p>Elija “Guardar como PDF” / “Save as PDF” en el diálogo de impresión.</p>
    </div>
    <div class="pf-print-toolbar__actions">
      <button type="button" class="pf-print-btn" onclick="window.print()">Imprimir / Guardar PDF</button>
      <a class="pf-print-btn pf-print-btn--ghost" href="/portafolio">Volver al digital</a>
    </div>
  </div>

  <section class="sheet cover">
    <div class="cover__bg" style="background-image:url('<%= p.coverImage %>')"></div>
    <div class="cover__veil"></div>
    <div class="cover__accent"></div>
    <div class="cover__content">
      <img src="<%= c.general.logoFooter || c.general.logoHero || '/images/logo.png' %>" alt="<%= site.name %>" class="cover__logo">
      <p class="cover__badge"><%= p.coverBadge %></p>
      <p class="cover__brand"><%= site.name %></p>
      <h1><%= p.coverTitle %></h1>
      <p class="cover__sub"><%= p.coverSubtitle %></p>
      <p class="cover__year"><%= p.coverYear %></p>
      <p class="cover__place"><%= site.address.city %> · <%= site.address.region %> · <%= site.address.country %></p>
    </div>
  </section>

  <section class="sheet stats-sheet">
    <p class="kicker"><%= p.statsTitle %></p>
    <div class="stats">
      <% (p.stats || []).forEach((item) => { %>
      <div class="stat">
        <strong><%= item.value %></strong>
        <span><%= item.label %></span>
      </div>
      <% }) %>
    </div>
  </section>

  <section class="sheet">
    <div class="split">
      <div>
        <p class="kicker">Empresa</p>
        <h2><%= p.introTitle %></h2>
        <p class="lead"><%= p.introLead %></p>
        <% (p.introParagraphs || []).forEach((para) => { %>
        <p class="body"><%= para %></p>
        <% }) %>
      </div>
      <div class="photo-frame">
        <img src="<%= p.introImage %>" alt="<%= p.introTitle %>">
      </div>
    </div>
    <div class="mission-row">
      <article>
        <h3><%= p.missionTitle %></h3>
        <p><%= p.missionText %></p>
      </article>
      <article>
        <h3><%= p.visionTitle %></h3>
        <p><%= p.visionText %></p>
      </article>
    </div>
  </section>

  <section class="sheet">
    <p class="kicker">Diferenciales</p>
    <h2><%= p.strengthsTitle %></h2>
    <p class="lead"><%= p.strengthsSubtitle %></p>
    <div class="cards-4">
      <% (p.strengths || []).forEach((item) => { %>
      <article class="card">
        <img src="<%= item.image || '/images/portfolio/pf-icon-energy.jpg' %>" alt="<%= item.title %>">
        <h3><%= item.title %></h3>
        <p><%= item.text %></p>
      </article>
      <% }) %>
    </div>
  </section>

  <section class="sheet dark-sheet">
    <p class="kicker">Capacidades</p>
    <h2><%= p.servicesTitle %></h2>
    <p class="lead light"><%= p.servicesSubtitle %></p>
    <div class="services">
      <% (p.services || []).forEach((item, i) => { %>
      <article>
        <span><%= String(i + 1).padStart(2, '0') %></span>
        <h3><%= item.title %></h3>
        <p><%= item.text %></p>
      </article>
      <% }) %>
    </div>
  </section>

  <section class="sheet">
    <p class="kicker">Divisiones</p>
    <h2><%= p.divisionsTitle %></h2>
    <p class="lead"><%= p.divisionsSubtitle %></p>
    <div class="divisions">
      <% (p.divisions || []).forEach((item, i) => { %>
      <article class="division">
        <img src="<%= item.image %>" alt="<%= item.title %>">
        <div>
          <span><%= String(i + 1).padStart(2, '0') %></span>
          <h3><%= item.title %></h3>
          <p><%= item.text %></p>
        </div>
      </article>
      <% }) %>
    </div>
  </section>

  <section class="sheet">
    <p class="kicker">Método</p>
    <h2><%= p.processTitle %></h2>
    <p class="lead"><%= p.processSubtitle %></p>
    <div class="steps">
      <% (p.processSteps || []).forEach((item, i) => { %>
      <div>
        <span><%= String(i + 1).padStart(2, '0') %></span>
        <strong><%= item.title %></strong>
        <p><%= item.text %></p>
      </div>
      <% }) %>
    </div>
  </section>

  <section class="sheet">
    <p class="kicker">Experiencia</p>
    <h2><%= p.projectsTitle %></h2>
    <p class="lead"><%= p.projectsSubtitle %></p>
    <div class="projects">
      <% (p.projects || []).forEach((item) => { %>
      <article class="project">
        <img src="<%= item.image %>" alt="<%= item.title %>">
        <div>
          <p class="meta"><%= [item.category, item.client].filter(Boolean).join(' · ') %></p>
          <h3><%= item.title %></h3>
          <p><%= item.text %></p>
          <% if (item.scope) { %><p class="scope"><%= item.scope %></p><% } %>
        </div>
      </article>
      <% }) %>
    </div>
  </section>

  <section class="sheet">
    <p class="kicker">Confianza</p>
    <h2><%= p.clientsTitle %></h2>
    <p class="lead"><%= p.clientsSubtitle %></p>
    <div class="clients">
      <% (p.clients || []).forEach((item) => { %>
      <figure>
        <img src="<%= item.logo %>" alt="<%= item.name %>">
        <figcaption><%= item.name %></figcaption>
      </figure>
      <% }) %>
    </div>
  </section>

  <section class="sheet closing">
    <div class="closing__bg" style="background-image:url('<%= p.closingImage || p.coverImage %>')"></div>
    <div class="closing__veil"></div>
    <div class="closing__content">
      <h2><%= p.closingTitle %></h2>
      <p><%= p.closingText %></p>
      <p class="contact"><%= p.contactNote %></p>
      <p class="url"><%= site.url %>/portafolio</p>
    </div>
  </section>

  <script>
    if (document.body.classList.contains('pf-print--auto')) {
      window.addEventListener('load', () => setTimeout(() => window.print(), 500));
    }
  </script>
</body>
</html>
