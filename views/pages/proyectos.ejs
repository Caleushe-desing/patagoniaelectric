<%- include('../partials/head') %>
<%- include('../partials/header') %>
<% const p = c.proyectos; %>

<section class="page-hero">
  <div class="page-hero__bg" style="background-image:url('<%= p.heroImage %>')" <%- cmsAttr('proyectos', 'heroImage', { type: 'bg-image' }) %>></div>
  <div class="page-hero__overlay"></div>
  <div class="container page-hero__content">
    <h1 class="page-hero__title" <%- cmsAttr('proyectos', 'heroTitle') %>><%= p.heroTitle %></h1>
    <p class="page-hero__subtitle" <%- cmsAttr('proyectos', 'heroSubtitle') %>><%= p.heroSubtitle %></p>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section__header">
      <h2 class="section__title" <%- cmsAttr('proyectos', 'title') %>><%= p.title %></h2>
      <p class="section__subtitle" <%- cmsAttr('proyectos', 'subtitle') %>><%= p.subtitle %></p>
    </div>
    <div class="projects" <%- cmsList('proyectos', 'items') %>>
      <% p.items.forEach((item, i) => { %>
      <article class="project-card" data-cms-item="<%= i %>">
        <img src="<%= item.image %>" alt="<%= item.title %>" loading="lazy" <%- cmsAttr('proyectos', 'image', { arrayField: 'items', index: i, type: 'image' }) %>>
        <div class="project-card__overlay">
          <h4 class="project-card__title" <%- cmsAttr('proyectos', 'title', { arrayField: 'items', index: i }) %>><%= item.title %></h4>
          <p class="project-card__desc" <%- cmsAttr('proyectos', 'text', { arrayField: 'items', index: i }) %>><%= item.text %></p>
        </div>
      </article>
      <% }) %>
    </div>
  </div>
</section>

<section class="section section--gray">
  <div class="container" style="text-align:center;">
    <h2 class="section__title section__title--green" <%- cmsAttr('proyectos', 'ctaTitle') %>><%= p.ctaTitle %></h2>
    <a href="/contacto" class="btn btn--primary cms-allow-link"><span <%- cmsAttr('proyectos', 'ctaButton') %>><%= p.ctaButton %></span></a>
  </div>
</section>

<%- include('../partials/footer') %>
<%- include('../partials/whatsapp') %>
<%- include('../partials/scripts') %>
</body>
</html>
