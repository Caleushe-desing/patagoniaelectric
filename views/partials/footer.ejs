<footer class="footer">
  <div class="container">
    <div class="footer__grid">
      <div class="footer__brand">
        <a href="/" class="logo logo--footer">
          <img
            src="<%= (typeof c !== 'undefined' && c.general.logoFooter) ? c.general.logoFooter : '/images/logo.png' %>"
            alt=""
            class="footer__logo"
            width="106"
            height="120"
            loading="lazy"
            <%- typeof cmsAttr !== 'undefined' ? cmsAttr('general', 'logoFooter', { type: 'image' }) : '' %>
          >
          <span class="brand-name" aria-label="Patagonia Electric">
            <span class="brand-name__patagonia">Patagonia</span>
            <span class="brand-name__electric">Electric</span>
          </span>
        </a>
        <p><%= typeof c !== 'undefined' ? c.general.footerText : site.legalName %></p>
      </div>
      <div>
        <h4 class="footer__title">Enlaces</h4>
        <ul class="footer__links">
          <li><a href="/">Inicio</a></li>
          <li><a href="/nosotros">Nosotros</a></li>
          <li><a href="/industrial">Industrial</a></li>
          <li><a href="/division-ecologica">División Ecológica</a></li>
          <li><a href="/habitacional">Habitacional</a></li>
          <li><a href="/proyectos">Proyectos</a></li>
          <li><a href="/contacto">Contacto</a></li>
        </ul>
      </div>
      <div>
        <h4 class="footer__title">Contacto</h4>
        <ul class="footer__links">
          <li><a href="mailto:<%= site.email %>"><%= site.email %></a></li>
          <li><a href="tel:<%= site.phoneRaw %>"><%= site.phone %></a></li>
          <li><%= site.address.city %>, <%= site.address.country %></li>
          <li><%= site.hours %></li>
        </ul>
      </div>
    </div>
    <div class="footer__bottom">
      <p>&copy; <%= new Date().getFullYear() %> Patagonia Electric. Todos los derechos reservados. · <a href="/admin" class="footer__admin-link">Admin</a></p>
    </div>
  </div>
</footer>
